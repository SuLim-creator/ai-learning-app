{
  "permissions": {
    "allow": [
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run test)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": ["Bash(rm -rf*)", "Bash(git push --force*)", "Read(**/.env*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; npx prettier --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Prettier 포맷 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty' 2>/dev/null) || exit 0; echo \"$cmd\" | grep -qE '(rm -rf|DROP TABLE|git push --force)' && echo '차단: 위험한 명령어가 감지되었습니다.' && exit 2; exit 0"
          }
        ]
      }
    ]
  }
}
