generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Stage {
  id          String @id @default(cuid())
  title       String
  description String
  order       Int    @unique

  lessons Lesson[]
}

model Lesson {
  id               String @id @default(cuid())
  stageId          String
  title            String
  description      String
  order            Int
  estimatedMinutes Int

  stage Stage @relation(fields: [stageId], references: [id])

  @@unique([stageId, order])
}

model GeneratedContent {
  id        String   @id @default(cuid())
  lessonId  String
  version   Int      @default(1)
  content   String   // JSON string of LessonSection[]
  createdAt DateTime @default(now())

  @@unique([lessonId, version])
  @@index([lessonId])
}
